ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_AVATAR_ID=your_avatar_id_here
HEYGEN_VOICE_ID=your_voice_id_here

# Set to "true" to use Avatar V engine (check your avatar supports it)
HEYGEN_USE_AVATAR_V=false

# AI provider: "claude" or "gemini"
AI_PROVIDER=claude

# GNews API key (free at https://gnews.io — 100 req/day free)
GNEWS_API_KEY=
